{
  "manifest_version": 3,
  "name": "Video PiP Shortcut",
  "description": "Adds a Picture‑in‑Picture overlay button and a customisable keyboard shortcut to HTML5 videos.",
  "version": "1.12",
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "video-pip-shortcut@beficent.github.io",
      "strict_min_version": "153.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["settings-config.js", "content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon.png"
  }
}
