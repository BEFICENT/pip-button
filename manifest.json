{
  "manifest_version": 3,
  "name": "Video PiP Shortcut",
  "description": "Adds a Picture‑in‑Picture overlay button and a customisable keyboard shortcut to HTML5 videos.",
  "version": "1.11",
  "permissions": ["storage"],
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["settings-config.js", "content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
